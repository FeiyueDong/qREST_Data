{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug Python Module (input)",
            "type": "debugpy",
            "request": "launch",
            "module": "${input:moduleName}",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "justMyCode": true
        },
        {
            "type": "cmake",
            "request": "launch",
            "name": "Debug portfile(s)",
            "cmakeDebugType": "external",
            "pipeName": "\\\\.\\pipe\\vcpkg_ext_portfile_dbg",
            "preLaunchTask": "Debug vcpkg commands"
        }
    ],
    "inputs": [
        {
            "id": "moduleName",
            "type": "promptString",
            "description": "Input python module (e.g. py_scripts.test.test_edp)",
            "default": "py_scripts.test.test_edp"
        }
    ]
}